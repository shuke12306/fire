<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <ImageView
        android:id="@+id/profile_avatar"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:contentDescription="@string/content_desc_avatar"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/profile_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="@style/TextAppearance.AppCompat.Headline"
        android:textColor="@color/fire_text_primary" />

    <TextView
        android:id="@+id/profile_trust_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/TextAppearance.AppCompat.Caption"
        android:textColor="@color/fire_accent" />

    <TextView
        android:id="@+id/profile_bio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textColor="@color/fire_text_secondary"
        android:visibility="gone" />

    <TextView
        android:id="@+id/profile_follow_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:textAppearance="@style/TextAppearance.AppCompat.Button"
        android:textColor="@color/fire_accent"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>