<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Fire" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fire_accent</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/fire_chip_accent_background</item>
        <item name="colorOnPrimaryContainer">@color/fire_text_primary</item>
        <item name="colorSecondary">@color/fire_accent_soft</item>
        <item name="colorSecondaryContainer">@color/fire_chip_accent_background</item>
        <item name="colorOnSecondaryContainer">@color/fire_text_primary</item>
        <item name="colorSurface">@color/fire_background_surface</item>
        <item name="colorSurfaceVariant">@color/fire_background_elevated</item>
        <item name="colorOnSurface">@color/fire_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/fire_text_secondary</item>
        <item name="colorOutline">@color/fire_divider</item>
        <item name="android:statusBarColor" tools:targetApi="l">?android:colorBackground</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/fire_background_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>
</resources>
